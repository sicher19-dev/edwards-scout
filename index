/* ===================== render ===================== */
const $ = (id)=>document.getElementById(id);
let state = { team:0, metric: ARM_DATA.zoneMetrics[0].key, hitter:null };

function tierClass(t){return t;}
function colorScale(metric, v){
  // returns a green->yellow->red color. xwobacon ~ .250-.700; whiff% inverse; freq neutral
  let t;
  if(metric==="xwobacon"){ t=(v-.260)/(.700-.260); }
  else if(metric==="whiff"){ t=1-((v-7)/(34-7)); }      // high whiff = good for pitcher = cold
  else { t=(v-7)/(16-7); }                               // freq: just density
  t=Math.max(0,Math.min(1,t));
  // green(31,138,76) -> yellow(212,209,82) -> red(239,83,80)
  let r,g,b;
  if(t<.5){const k=t/.5; r=31+(212-31)*k; g=138+(209-138)*k; b=76+(82-76)*k;}
  else{const k=(t-.5)/.5; r=212+(239-212)*k; g=209+(83-209)*k; b=82+(80-82)*k;}
  return `rgb(${r|0},${g|0},${b|0})`;
}
function fmt(metric,v){ return metric==="xwobacon" ? v.toFixed(3).replace(/^0/,'') : v+(metric==="whiff"||metric==="freq"?"%":""); }

function renderArm(){
  const m=ARM_DATA.meta;
  $('armName').textContent=m.name;
  $('armSub').innerHTML=m.line+'  ·  <b>'+m.asOf+'</b>';
  $('armRep').innerHTML=ARM_DATA.repertoire.map(p=>
    `<span class="pill"><span class="dot" style="background:${p.color}"></span>${p.name}</span>`).join('');
  $('sampleBadge').style.display = m.isSample ? '' : 'none';
  $('footSrc').textContent=m.source;
  $('footNote').textContent=m.note;
  $('keys').innerHTML=ARM_DATA.keys.map(k=>
    `<div class="key"><div class="num">${k.n}</div><div class="txt">${k.html}</div></div>`).join('');
  $('metricToggle').innerHTML=ARM_DATA.zoneMetrics.map(z=>
    `<button data-k="${z.key}" class="${z.key===state.metric?'on':''}" onclick="setMetric('${z.key}')">${z.label}</button>`).join('');
}
function renderTeams(){
  $('teams').innerHTML=ARM_DATA.opponents.map((t,i)=>
    `<button class="team ${i===state.team?'on':''}" onclick="setTeam(${i})">${t.abbr} ${t.name}</button>`).join('');
}
function renderCards(){
  const t=ARM_DATA.opponents[state.team];
  $('cards').innerHTML=t.hitters.map((h,i)=>`
    <div class="hcard" onclick="openSheet(${i})">
      <div class="row1">
        <span class="slot">${h.slot}</span>
        <span class="tier ${tierClass(h.tier)}">${h.tier}</span>
      </div>
      <h3>${h.name}</h3>
      <div class="meta">${h.bats}HH · ${h.pos} · wOBA ${h.woba}</div>
      <div class="aa">
        <div class="box attack"><div class="lab">ATTACK</div><div class="val">${h.attack}</div></div>
        <div class="box avoid"><div class="lab">AVOID</div><div class="val">${h.avoid}</div></div>
      </div>
      <div class="tapcue">tap ›</div>
    </div>`).join('');
}
function renderZone(){
  if(state.hitter===null)return;
  const h=ARM_DATA.opponents[state.team].hitters[state.hitter];
  const g=(h.zone&&h.zone[state.metric])||[];
  $('zone').innerHTML=g.map(v=>`<div class="cell" style="background:${colorScale(state.metric,v)}">${fmt(state.metric,v)}</div>`).join('');
  const lab=ARM_DATA.zoneMetrics.find(z=>z.key===state.metric).label;
  $('zoneMetricLabel').textContent=lab+" by zone";
}
function openSheet(i){
  state.hitter=i;
  const h=ARM_DATA.opponents[state.team].hitters[i];
  $('dName').textContent=h.name;
  $('dMeta').textContent=`${h.bats}HH · ${h.pos} · wOBA ${h.woba}`;
  $('dTier').textContent=h.tier; $('dTier').className='tier '+tierClass(h.tier);
  $('dAttack').textContent=h.attack; $('dAvoid').textContent=h.avoid;
  $('dNote').textContent=h.note||'';
  renderZone();
  renderBuckets(h);
  $('sheetBg').classList.add('on'); $('sheet').classList.add('on');
}
function renderBuckets(h){
  // derive simple bucket bars from the zone xwobacon (min/middle/max regions) if no explicit buckets
  const z=(h.zone&&h.zone.xwobacon)||[];
  const rows=[
    {nm:"Heater up", v:(z[0]+z[1]+z[2])/3},
    {nm:"Middle / hittable", v:(z[3]+z[4]+z[5])/3},
    {nm:"Down / spin", v:(z[6]+z[7]+z[8])/3}
  ];
  $('buckets').innerHTML=rows.map(r=>`
    <div class="bucket">
      <div class="top"><span class="nm">${r.nm}</span><span class="vl">${r.v.toFixed(3).replace(/^0/,'')} xwOBACON</span></div>
      <div class="track"><div class="fill" style="width:${Math.max(6,Math.min(100,(r.v-.250)/(.700-.250)*100))}%;background:${colorScale('xwobacon',r.v)}"></div></div>
    </div>`).join('');
}
function setMetric(k){ state.metric=k; document.querySelectorAll('#metricToggle button').forEach(b=>b.classList.toggle('on',b.dataset.k===k)); renderZone(); }
function setTeam(i){ state.team=i; renderTeams(); renderCards(); }
function closeSheet(){ $('sheetBg').classList.remove('on'); $('sheet').classList.remove('on'); state.hitter=null; }

renderArm(); renderTeams(); renderCards();
</script>
