  </div>

</div>

<!-- HITTER DETAIL SHEET -->
<div class="sheet-bg" id="sheetBg" onclick="closeSheet()"></div>
<div class="sheet" id="sheet">
  <div class="grab"></div>
  <div class="sh1">
