    <div class="rep" id="armRep"></div>
  </div>

  <!-- BOTTOM LINE -->
  <div class="sec">
    <div class="sec-h">Bottom Line — 5 Keys</div>
    <div class="keys" id="keys"></div>
  </div>

  <!-- OPPONENTS -->
  <div class="sec">
    <div class="sec-h">Opponents — Tap a Team</div>
    <div class="legend">
      <span><i style="background:var(--elite)"></i>Elite</span>
      <span><i style="background:var(--high)"></i>High</span>
      <span><i style="background:var(--med)"></i>Med</span>
      <span><i style="background:var(--low)"></i>Low</span>
    </div>
    <div class="hint">ATTACK / AVOID = your best & worst bucket by xwOBACON · tap a hitter for the in-zone map</div>
    <div class="teams" id="teams"></div>
