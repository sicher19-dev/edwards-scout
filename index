<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Arm Scout — No Brand Baseball Analytics</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700;900&family=Archivo+Narrow:wght@600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
/* ============================================================
   ARM SCOUT — reusable per-arm pregame scouting tool
   No Brand Baseball Analytics
   Single file. All data lives in the ARM_DATA block below.
   Swap ARM_DATA to retarget the tool to any pitcher.
   ============================================================ */
:root{
  --bg:#0a0a0b; --bg2:#111114; --card:#16161a; --card2:#1c1c22;
  --line:#2a2a31; --ink:#f2f2f0; --dim:#8b8b93; --dimmer:#5c5c63;
  --gold:#f0b429; --gold-soft:#caa14a;
  --elite:#ef5350; --elite-bg:rgba(239,83,80,.10); --elite-line:rgba(239,83,80,.45);
  --high:#f0a829;  --high-bg:rgba(240,168,41,.08);  --high-line:rgba(240,168,41,.45);
  --med:#d4d152;   --med-bg:rgba(212,209,82,.07);   --med-line:rgba(212,209,82,.4);
  --low:#54d98c;   --low-bg:rgba(84,217,140,.07);   --low-line:rgba(84,217,140,.4);
  --attack:#54d98c; --attack-bg:rgba(84,217,140,.06); --attack-line:rgba(84,217,140,.35);
  --avoid:#ef6b6b;  --avoid-bg:rgba(239,107,107,.06); --avoid-line:rgba(239,107,107,.35);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{margin:0;padding:0;background:var(--bg);color:var(--ink)}
body{
  font-family:'Archivo',sans-serif; line-height:1.45;
  background:
    radial-gradient(1200px 600px at 80% -10%, rgba(240,180,41,.05), transparent 60%),
    radial-gradient(900px 500px at -10% 100%, rgba(84,217,140,.03), transparent 55%),
    var(--bg);
  min-height:100vh; padding-bottom:64px;
}
.wrap{max-width:760px;margin:0 auto;padding:0 16px}
.mono{font-family:'JetBrains Mono',monospace}

/* ---------- top bar ---------- */
.topbar{
  display:flex;align-items:center;justify-content:space-between;gap:10px;
  padding:18px 16px 14px;max-width:760px;margin:0 auto;
}
.brand{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;color:var(--gold-soft);text-transform:uppercase}
.sample{
  font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;
  color:#ffd27a;border:1px solid rgba(240,180,41,.4);background:rgba(240,180,41,.08);
  padding:4px 8px;border-radius:5px;white-space:nowrap
}

/* ---------- arm header ---------- */
.arm{padding:6px 0 8px}
.arm h1{
  font-family:'Archivo',sans-serif;font-weight:900;font-size:42px;line-height:.95;
  letter-spacing:-.02em;margin:0;text-transform:uppercase
}
.arm .sub{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--dim);margin-top:8px;letter-spacing:.04em}
.arm .sub b{color:var(--ink);font-weight:700}
.rep{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px}
.pill{
  font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.03em;
  padding:4px 9px;border-radius:99px;border:1px solid var(--line);color:var(--dim);
  display:inline-flex;align-items:center;gap:6px
}
.pill .dot{width:7px;height:7px;border-radius:99px}

/* ---------- section heading ---------- */
.sec{margin-top:30px}
.sec-h{
  font-family:'Archivo Narrow',sans-serif;font-weight:700;font-size:21px;letter-spacing:.06em;
  color:var(--gold);text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:14px
}
.sec-h::after{content:"";flex:1;height:1px;background:linear-gradient(90deg,var(--line),transparent)}

/* ---------- bottom line keys ---------- */
.keys{border:1px solid var(--high-line);border-radius:16px;background:linear-gradient(180deg,rgba(240,180,41,.04),rgba(240,180,41,.01));padding:6px 18px}
.key{display:flex;gap:16px;padding:18px 0;border-bottom:1px solid var(--line)}
.key:last-child{border-bottom:0}
.key .num{
  flex:none;width:30px;height:30px;border-radius:99px;background:var(--gold);color:#1a1400;
  font-family:'Archivo',sans-serif;font-weight:900;font-size:15px;display:grid;place-items:center;margin-top:2px
}
.key .txt{font-size:16px;line-height:1.5;color:#dcdcd8}
.key .txt b{color:#fff;font-weight:700}
.g{color:var(--low);font-weight:600}.r{color:var(--avoid);font-weight:600}.y{color:var(--gold);font-weight:600}

/* ---------- legend ---------- */
.legend{display:flex;flex-wrap:wrap;gap:14px;margin-bottom:8px}
.legend span{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);display:inline-flex;align-items:center;gap:6px}
.legend i{width:11px;height:11px;border-radius:3px;display:inline-block}
.hint{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dimmer);margin:6px 0 16px;letter-spacing:.02em}

/* ---------- team selector ---------- */
.teams{display:flex;gap:8px;overflow-x:auto;padding:2px 2px 10px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.teams::-webkit-scrollbar{display:none}
.team{
  flex:none;font-family:'Archivo Narrow',sans-serif;font-weight:700;font-size:14px;letter-spacing:.04em;
  padding:9px 15px;border-radius:11px;border:1px solid var(--line);background:var(--card);color:var(--dim);
  cursor:pointer;transition:.15s;white-space:nowrap;text-transform:uppercase
}
.team:hover{border-color:var(--dimmer);color:var(--ink)}
.team.on{background:var(--gold);border-color:var(--gold);color:#1a1400}

/* ---------- hitter cards ---------- */
.cards{display:flex;flex-direction:column;gap:12px}
.hcard{
  border:1px solid var(--line);border-radius:16px;background:var(--card);padding:16px 16px 14px;cursor:pointer;
  transition:.15s;position:relative;overflow:hidden
}
.hcard:active{transform:scale(.992)}
.hcard:hover{border-color:var(--dimmer)}
.hcard .row1{display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
.hcard .slot{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--dimmer)}
.tier{
  font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.12em;
  padding:4px 9px;border-radius:7px;text-transform:uppercase
}
.tier.elite{color:var(--elite);background:var(--elite-bg);border:1px solid var(--elite-line)}
.tier.high{color:var(--high);background:var(--high-bg);border:1px solid var(--high-line)}
.tier.med{color:var(--med);background:var(--med-bg);border:1px solid var(--med-line)}
.tier.low{color:var(--low);background:var(--low-bg);border:1px solid var(--low-line)}
.hcard h3{font-family:'Archivo',sans-serif;font-weight:900;font-size:27px;letter-spacing:-.01em;margin:2px 0 4px;text-transform:uppercase}
.hcard .meta{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--dim);letter-spacing:.03em}
.aa{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px}
.aa .box{border-radius:11px;padding:10px 12px;text-align:center}
.aa .box .lab{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:.14em}
.aa .box .val{font-family:'Archivo Narrow',sans-serif;font-weight:700;font-size:15px;margin-top:3px}
.aa .attack{background:var(--attack-bg);border:1px solid var(--attack-line)}
.aa .attack .lab{color:var(--attack)} .aa .attack .val{color:#bff0d4}
.aa .avoid{background:var(--avoid-bg);border:1px solid var(--avoid-line)}
.aa .avoid .lab{color:var(--avoid)} .aa .avoid .val{color:#f3c4c4}
.tapcue{position:absolute;right:14px;bottom:12px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dimmer);letter-spacing:.08em}

/* ---------- hitter detail (sheet) ---------- */
.sheet-bg{position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(3px);opacity:0;pointer-events:none;transition:.2s;z-index:40}
.sheet-bg.on{opacity:1;pointer-events:auto}
.sheet{
  position:fixed;left:50%;bottom:0;transform:translate(-50%,100%);width:100%;max-width:760px;
  background:var(--bg2);border:1px solid var(--line);border-bottom:0;border-radius:20px 20px 0 0;
  z-index:50;transition:transform .26s cubic-bezier(.22,1,.36,1);max-height:92vh;overflow-y:auto;padding:8px 18px 36px
}
.sheet.on{transform:translate(-50%,0)}
.grab{width:42px;height:4px;border-radius:99px;background:var(--line);margin:8px auto 12px}
.sheet .sh1{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
.sheet h2{font-family:'Archivo',sans-serif;font-weight:900;font-size:30px;letter-spacing:-.01em;margin:0;text-transform:uppercase}
.sheet .smeta{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--dim);margin-top:6px;letter-spacing:.03em}
.blk-h{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;color:var(--gold-soft);text-transform:uppercase;margin:24px 0 12px}

/* zone grid */
.zonewrap{display:flex;gap:18px;align-items:center;flex-wrap:wrap}
.zone{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;width:200px}
.cell{aspect-ratio:1;border-radius:7px;display:grid;place-items:center;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;color:#0c0c0c}
.zlabels{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);line-height:1.7}
.zlabels .scale{display:flex;align-items:center;gap:7px;margin-top:8px}
.scale .bar{width:90px;height:9px;border-radius:99px;background:linear-gradient(90deg,#1f8a4c,#d4d152,#ef5350)}
.toggle{display:flex;gap:6px;margin:12px 0 4px;flex-wrap:wrap}
.toggle button{
  font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;
  padding:6px 11px;border-radius:8px;border:1px solid var(--line);background:var(--card);color:var(--dim);cursor:pointer
}
.toggle button.on{background:var(--card2);border-color:var(--gold-soft);color:var(--gold)}

/* buckets */
.bucket{margin:10px 0}
.bucket .top{display:flex;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:12px;margin-bottom:5px}
.bucket .top .nm{color:#d8d8d4}.bucket .top .vl{color:var(--dim)}
.track{height:9px;border-radius:99px;background:var(--card2);overflow:hidden}
.fill{height:100%;border-radius:99px}
.note{font-family:'JetBrains Mono',monospace;font-size:11.5px;color:var(--dim);line-height:1.6;margin-top:6px}

/* footer */
.foot{max-width:760px;margin:34px auto 0;padding:18px 16px 0;border-top:1px solid var(--line)}
.foot p{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dimmer);line-height:1.7;letter-spacing:.02em;margin:3px 0}
.foot .src{color:var(--gold-soft)}
</style>
</head>
