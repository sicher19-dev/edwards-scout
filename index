      <div class="scale"><span style="color:var(--low)">cold</span><span class="bar"></span><span style="color:var(--elite)">hot</span></div>
    </div>
  </div>

  <div class="blk-h">Pitch-Bucket Damage</div>
  <div id="buckets"></div>

  <div class="blk-h">Plan</div>
  <div class="aa" style="margin-top:0">
    <div class="box attack"><div class="lab">ATTACK</div><div class="val" id="dAttack">—</div></div>
    <div class="box avoid"><div class="lab">AVOID</div><div class="val" id="dAvoid">—</div></div>
  </div>
  <div class="note" id="dNote"></div>
</div>

<div class="foot">
  <p class="src" id="footSrc">Data: —</p>
  <p id="footNote">—</p>
  <p>No Brand Baseball Analytics · Arm Scout</p>
</div>

